# Required
APP_ENV=development
PORT=8000
DATABASE_URL=<set-local-database-url>
JWT_SECRET=<set-local-jwt-secret>
SERVICE_NAME=api-service

# Required: environment-specific allowed frontend origin
# Development example: http://localhost:3000
# Production example: https://yourdomain.com
CORS_ORIGIN=<set-allowed-origin>

# Optional integrations
MONGODB_URI=
REDIS_URL=
API_KEY_A=<set-local-api-key-a>
API_KEY_B=<set-local-api-key-b>

# Optional tuning values
CREATE_LINK_PER_MIN=30
LINKS_READ_PER_MIN=60
REDIRECT_PER_MIN=120
ANALYTICS_RETENTION_DAYS=30